// Firestore security rules — mirror of what's deployed in the Firebase
// Console. This file lives in the repo so we have a shared source of
// truth for what permissions look like across the app's collections.
//
// IMPORTANT: This file is not deployed automatically. After editing,
// copy the contents into the Firebase Console (Firestore → Rules) and
// publish, OR set up `firebase deploy --only firestore:rules` if you
// want CLI deploys. Either way, keep this file in sync with what's live.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------- users subtree --------
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /friends/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /friendSubscriptions/{friendUid} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
      match /blocks/{blockedUid} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
      match /pushTokens/{docId} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // -------- Favorites --------
    match /Favorites/{userId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // -------- Friends doc (array) --------
    match /Friends/{userId} {
      allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // -------- FriendEdges --------
    match /FriendEdges/{edgeId} {
      function authed()         { return request.auth != null; }
      function isParticipant(d) {
        return authed()
               && d != null
               && d.uids is list
               && d.uids.size() == 2
               && d.uids.hasAny([request.auth.uid]);
      }
      allow read: if isParticipant(resource.data);
      allow create: if authed()
                    && request.resource.data.uids is list
                    && request.resource.data.uids.size() == 2
                    && request.resource.data.uids.hasAny([request.auth.uid])
                    && request.resource.data.uids[0] != request.resource.data.uids[1];
      allow delete: if isParticipant(resource.data);
      allow update: if false;
    }

    // -------- FriendRequests --------
    match /FriendRequests/{requestId} {
      function authed()        { return request.auth != null; }
      function sender(d)       { return authed() && d.senderUid == request.auth.uid; }
      function receiver(d)     { return authed() && d.receiverUid == request.auth.uid; }
      function isParticipant(d){ return authed() && (sender(d) || receiver(d)); }

      allow create: if authed()
                    && request.resource.data.senderUid == request.auth.uid
                    && request.resource.data.status == "pending";
      allow read: if isParticipant(resource.data);
      allow update: if authed() && (
        (receiver(resource.data) && resource.data.status == "pending" &&
          (request.resource.data.status == "accepted" || request.resource.data.status == "rejected"))
        ||
        (sender(resource.data) && resource.data.status == "pending" &&
          request.resource.data.status == "cancelled")
      );
      allow delete: if isParticipant(resource.data) && resource.data.status != "pending";
    }

    // -------- Beacons + ChatMessages --------
    match /Beacons/{beaconId} {
      function authed()     { return request.auth != null; }
      function isOwner()    { return authed() && resource.data.ownerUid == request.auth.uid; }
      function isAllowed()  {
        return authed()
               && resource.data.allowedUids is list
               && resource.data.allowedUids.hasAny([request.auth.uid]);
      }
      function currentInUids() {
        return (resource.data.inUids is list) ? resource.data.inUids : [];
      }

      allow read: if true;
      allow create: if authed()
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if authed() && (
        isOwner() ||
        (
          isAllowed() &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['inUids','updatedAt']) &&
          request.resource.data.inUids is list &&
          request.resource.data.inUids.hasAll(currentInUids()) &&
          request.resource.data.inUids.size() >= currentInUids().size()
        )
      );
      allow delete: if isOwner();

      match /ChatMessages/{msgId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && resource.data.authorUid == request.auth.uid;
        allow update: if false;
      }
    }

    // -------- Profiles + lists subcollection --------
    match /Profiles/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /lists/{listId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // -------- FriendGroups --------
    match /FriendGroups/{groupId} {
      function authed()     { return request.auth != null; }
      function isOwner()    { return authed() && resource.data.ownerUid == request.auth.uid; }
      function ownerStable(){ return authed() && request.resource.data.ownerUid == request.auth.uid; }

      allow read: if isOwner();
      allow create: if ownerStable()
                    && request.resource.data.name is string
                    && request.resource.data.memberUids is list;
      allow update: if isOwner()
                    && request.resource.data.ownerUid == resource.data.ownerUid
                    && request.resource.data.diff(resource.data).changedKeys()
                         .hasOnly(['name','memberUids','updatedAt']);
      allow delete: if isOwner();
    }

    // -------- Posts (top-level) + comments --------
    match /Posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;

      match /comments/{commentId} {
        function authed()    { return request.auth != null; }
        function isAuthor()  { return authed() && resource.data.authorUid == request.auth.uid; }
        function createsAsSelf() {
          return authed() && request.resource.data.authorUid == request.auth.uid;
        }
        allow read: if true;
        allow create: if createsAsSelf();
        allow update: if isAuthor();
        allow delete: if isAuthor();
      }
    }

    // -------- Reports (UGC moderation) --------
    match /Reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // -------- PushTokens --------
    match /PushTokens/{uid} {
      allow read, create, update, delete: if request.auth != null && request.auth.uid == uid;
    }

    // -------- Vacation Days (habit-tracking breaks) --------
    // Doc id: `${userId}_${date}`. Each doc stores userId for queries.
    match /vacationDays/{docId} {
      function authed()    { return request.auth != null; }
      function isOwner()   { return authed() && resource.data.userId == request.auth.uid; }
      function ownsNew()   { return authed() && request.resource.data.userId == request.auth.uid; }

      allow read: if isOwner();
      allow create: if ownsNew();
      allow update: if isOwner()
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner();
    }

    // -------- Catch-all (unchanged) --------
    match /{document=**} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.author;
    }
  }
}
